FOVCircle.Visible = false

-- Bảng lưu trữ cấu trúc ESP (Gồm cả Hộp Khung và Đường Chỉ)
local ESPVisuals = {}

local function CreateESP(player)
    if player == LocalPlayer then return end
    
    local Visual = {
        Outline = Drawing.new("Square"),
        MainBox = Drawing.new("Square"),
        TracerLine = Drawing.new("Line") -- Thêm đường kẻ chỉ chân thực
    }
    
    -- Cấu hình viền ngoài hộp đen để đổ bóng sắc nét
    Visual.Outline.Color = Color3.fromRGB(0, 0, 0)
    Visual.Outline.Thickness = 3
    Visual.Outline.Filled = false
    Visual.Outline.Visible = false
    
    -- Cấu hình hộp chính màu TRẮNG BÌNH THƯỜNG theo yêu cầu
    Visual.MainBox.Color = Color3.fromRGB(255, 255, 255)
    Visual.MainBox.Thickness = 1.5
    Visual.MainBox.Filled = false
    Visual.MainBox.Visible = false
    
    -- Cấu hình ĐƯỜNG CHỈ TRACER màu TRẮNG
    Visual.TracerLine.Color = Color3.fromRGB(255, 255, 255)
    Visual.TracerLine.Thickness = 1.2
    Visual.TracerLine.Visible = false
    
    ESPVisuals[player] = Visual
end

-- Khởi tạo tự động cho người chơi cũ và mới gia nhập
for _, p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

-- Giải phóng bộ nhớ Core Drawing khi người chơi thoát
Players.PlayerRemoving:Connect(function(player)
    if ESPVisuals[player] then
        ESPVisuals[player].Outline:Remove()
        ESPVisuals[player].MainBox:Remove()
        ESPVisuals[player].TracerLine:Remove()
        ESPVisuals[player] = nil
    end
end)

-- Vòng lặp cập nhật vị trí đồng thời Khung Hộp + Đường Chỉ Trỏ thẳng tới mục tiêu
local function UpdateESP()
    for player, visual in pairs(ESPVisuals) do
        if BoxESPOn and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local RootPart = player.Character.HumanoidRootPart
            local Position, OnScreen = Camera:WorldToViewportPoint(RootPart.Position)
            
            if OnScreen then
                -- 1. XỬ LÝ KHUNG HỘP CHỮ NHẬT CO GIÃN MÀU TRẮNG
                local Scale = 1 / (Position.Z * 0.05) * 100
                local Width, Height = Scale * 0.6, Scale * 0.9
                
                visual.Outline.Size = Vector2.new(Width, Height)
                visual.Outline.Position = Vector2.new(Position.X - Width / 2, Position.Y - Height / 2)
                visual.Outline.Visible = true
                
                visual.MainBox.Size = Vector2.new(Width, Height)
                visual.MainBox.Position = Vector2.new(Position.X - Width / 2, Position.Y - Height / 2)
                visual.MainBox.Visible = true
                
                -- 2. XỬ LÝ ĐƯỜNG KẺ CHỈ NỐI TỪ ĐÁY MÀN HÌNH LÊN NGƯỜI PLAYER
                visual.TracerLine.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                visual.TracerLine.To = Vector2.new(Position.X, Position.Y + (Height / 2)) -- Chỉ vào phần chân khung để tạo góc nhìn thoáng nhất
                visual.TracerLine.Visible = true
            else
                visual.Outline.Visible = false
                visual.MainBox.Visible = false
                visual.TracerLine.Visible = false
            end
        else
            visual.Outline.Visible = false
            visual.MainBox.Visible = false
            visual.TracerLine.Visible = false
        end
    end
end

-- Thuật toán tìm kiếm mục tiêu trong phạm vi FOV (Khóa chuẩn vào Đầu)
local function GetClosestTarget()
    local Target = nil
    local MaxDistance = FOVOn and FOVCircle.Radius or math.huge
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Head") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            local Head = player.Character.Head
            local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Head.Position)
            
            if OnScreen then
                local MousePos = UserInputService:GetMouseLocation()
                local Distance = (Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos).Magnitude
                if Distance < MaxDistance then
                    MaxDistance = Distance
                    Target = Head
                end
            end
        end
    end
    return Target
end

-- Render xử lý liên tục
RunService.RenderStepped:Connect(function()
    local MousePos = UserInputService:GetMouseLocation()
    FOVCircle.Position = MousePos
    
    -- Thực thi vẽ ESP Kép (Hộp + Đường Chỉ Trỏ)
    pcall(UpdateESP)
    
    -- Thực thi điều hướng ngắm Aimbot xịn bằng chuột ảo
    if AimbotOn then
        local Target = GetClosestTarget()
        if Target then
            local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Target.Position)
            if OnScreen then
                local MainMousePos = UserInputService:GetMouseLocation()
                local AimX = (ScreenPos.X - MainMousePos.X) * 0.35 
                local AimY = (ScreenPos.Y - MainMousePos.Y) * 0.35
                
                mousemoverel(AimX, AimY) 
            end
        end
    end
end)

